# Copy this file to `.env.local` and fill in the values. Never commit `.env.local`.

# --- Resend (https://resend.com/api-keys) ---
RESEND_API_KEY=

# The "from" address. While using Resend's test domain you can only send to your
# own verified email. Swap to your verified domain later (e.g. Vital AI <hello@yourdomain.com>).
RESEND_FROM="Vital AI <onboarding@resend.dev>"

# --- Google Sheets (via Apps Script Web App) ---
# Deploy setup/waitlist-google-apps-script.gs as a Web App and paste its /exec URL here.
GOOGLE_SHEETS_WEBHOOK_URL=

# Shared secret. Set the SAME value in the Apps Script (SHARED_SECRET) to reject
# requests that don't come from this server. Leave both blank to skip the check.
GOOGLE_SHEETS_WEBHOOK_SECRET=
